// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id                  String              @id @default(cuid())
  slug                String              @unique
  name                String
  logoUrl             String?
  primaryColor        String              @default("#800020")
  bookingSubtitle     String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  adminCredential     AdminCredential?
  barbers             Barber[]
  bookings            Booking[]
  domains             ShopDomain[]
  scheduleExceptions  ScheduleException[]
  services            Service[]
  workingPeriods      ShopWorkingPeriod[]
}

model ShopDomain {
  id        String   @id @default(cuid())
  hostname  String   @unique
  shopId    String
  createdAt DateTime @default(now())
  shop      Shop     @relation(fields: [shopId], references: [id])

  @@index([shopId])
}

model ShopWorkingPeriod {
  id        String @id @default(cuid())
  shopId    String
  dayOfWeek Int
  startTime String
  endTime   String
  shop      Shop   @relation(fields: [shopId], references: [id])

  @@index([shopId, dayOfWeek])
}

model Barber {
  id          String    @id @default(cuid())
  shopId      String
  name        String
  image       String?
  bookings    Booking[]
  shop        Shop      @relation(fields: [shopId], references: [id])

  @@unique([shopId, name])
  @@index([shopId])
}

model Service {
  id          String    @id @default(cuid())
  shopId      String
  name        String    // π.χ. "Κούρεμα"
  duration    Int       // Διάρκεια σε λεπτά (π.χ. 30)
  price       Float     // Τιμή
  bookings    Booking[]
  shop        Shop      @relation(fields: [shopId], references: [id])

  @@unique([shopId, name])
  @@index([shopId])
}

enum BookingStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model ScheduleException {
  id          String   @id @default(uuid())
  shopId      String
  date        DateTime // The specific day affected
  barberName  String?  // If null, applies to the whole shop. Otherwise, specific barber.
  type        String   // "BLOCK_SLOT" (blocks a specific hour) or "FORCE_OPEN" (opens a Monday) or "FORCE_CLOSE"
  slotTime    String?  // e.g., "14:30" (only used if type is BLOCK_SLOT)
  createdAt   DateTime @default(now())
  shop        Shop     @relation(fields: [shopId], references: [id])

  @@index([shopId, date])
}

model AdminCredential {
  id           String   @id @default(cuid())
  shopId       String   @unique
  passwordHash String
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
  shop         Shop     @relation(fields: [shopId], references: [id])
}

model Booking {
  id          String   @id @default(cuid())
  shopId      String
  cancelToken String   @unique @default(cuid())
  createdAt   DateTime @default(now())
  startTime   DateTime // Η ώρα έναρξης του ραντεβού
  endTime     DateTime // Η ώρα λήξης (startTime + duration)
  status      BookingStatus @default(PENDING)

  // Στοιχεία Πελάτη
  customerName  String
  customerPhone String
  customerEmail String?
  noShow       Boolean @default(false)

  // Σχέσεις
  barberId    String
  barber      Barber   @relation(fields: [barberId], references: [id])
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id])
  shop        Shop     @relation(fields: [shopId], references: [id])

  @@index([shopId, startTime])
  @@index([shopId, barberId, startTime])
}
