// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Barber {
  id          String    @id @default(cuid())
  name        String
  image       String?
  bookings    Booking[]
}

model Service {
  id          String    @id @default(cuid())
  name        String    // π.χ. "Κούρεμα"
  duration    Int       // Διάρκεια σε λεπτά (π.χ. 30)
  price       Float     // Τιμή
  bookings    Booking[]
}

enum BookingStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Booking {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  startTime   DateTime // Η ώρα έναρξης του ραντεβού
  endTime     DateTime // Η ώρα λήξης (startTime + duration)
  status      BookingStatus @default(PENDING)

  // Στοιχεία Πελάτη
  customerName  String
  customerPhone String
  customerEmail String?

  // Σχέσεις
  barberId    String
  barber      Barber   @relation(fields: [barberId], references: [id])
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id])
}
